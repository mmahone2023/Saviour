# Sky Fortress reflection — server-side delivery (copy to .env.local)

# MongoDB Atlas (https://cloud.mongodb.com) — persist submissions
# Use Database > Connect > Drivers and paste the SRV connection string.
MONGODB_URI=
# Optional database name (default: saviour)
MONGODB_DB=

# Resend (https://resend.com) — transactional email
RESEND_API_KEY=
# Must be a verified sender, e.g. "Saviour <onboarding@yourdomain.com>"
RESEND_FROM_EMAIL=

# Twilio (https://www.twilio.com) — SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Your Twilio number in E.164, e.g. +15551234567
TWILIO_PHONE_NUMBER=
